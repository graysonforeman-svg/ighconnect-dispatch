{
  "name": "ighconnect-dispatch",
  "version": "0.0.1",
  "private": true,
  "workspaces": ["packages/shared"],
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "npm run build -w @igh-connect/shared && next dev -p 3000",
    "build": "npm run build -w @igh-connect/shared && next build",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@igh-connect/shared": "*",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "next": "^15.3.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.17",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
